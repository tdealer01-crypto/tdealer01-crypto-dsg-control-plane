# ============================================================================
# DSG Control Plane - Phase 8 Environment Variables Template
# ============================================================================
#
# SECURITY WARNING: This file contains example values for sensitive credentials
# DO NOT commit your real .env.local file to version control
#
# Instructions:
#   1. Copy this file: cp .env.example.stripe-app .env.local
#   2. Edit .env.local with your actual credentials
#   3. Add .env.local to .gitignore (should be automatic)
#   4. Run: ./scripts/env-setup-wizard.sh (recommended - guides you through setup)
#   5. Deploy to Vercel: ./scripts/env-to-vercel.sh
#
# For security best practices, see: docs/ENV_VARS_SECURITY_GUIDE.md
#
# ============================================================================

# ============================================================================
# APPLICATION URLS
# ============================================================================
# Set these to your production or staging domain

# Your app's public-facing URL (visible to browsers)
# Example: https://example.com or https://app-staging.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Your app's internal base URL (server-side operations)
# Example: https://example.com
APP_URL=http://localhost:3000

# ============================================================================
# STRIPE BILLING CONFIGURATION
# ============================================================================
# Get these from: https://dashboard.stripe.com/apikeys
#
# WARNING: STRIPE_SECRET_KEY is sensitive. Never expose to frontend.
#          Always set in Vercel server environment only.

# Stripe Secret API Key - for server-side operations only
# Format: sk_live_... (production) or sk_test_... (testing)
# Get from: Stripe Dashboard → Developers → API Keys → Secret key
# SECURITY: Keep this SECRET. Never expose to browser.
STRIPE_SECRET_KEY=sk_test_51234567890abcdefghijklmnop

# Stripe Webhook Secret - validates incoming webhook events
# Format: whsec_...
# Get from: Stripe Dashboard → Developers → Webhooks → Signing secret
# SECURITY: Keep this SECRET. Never expose to browser.
STRIPE_WEBHOOK_SECRET=whsec_test_1234567890abcdefghijklmnop

# Stripe Price ID for Pro Plan
# Format: price_...
# Get from: Stripe Dashboard → Products → [Your Product] → Pricing
# Example for a $99/month Pro plan: price_1234567890abcdefghijklmnop
STRIPE_PRICE_PRO=price_1234567890abcdefghijklmnop

# Stripe Price ID for Business Plan
# Format: price_...
# Get from: Stripe Dashboard → Products → [Your Product] → Pricing
# Example for a $499/month Business plan: price_0987654321zyxwvutsrqponml
STRIPE_PRICE_BUSINESS=price_0987654321zyxwvutsrqponml

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# PostgreSQL backend for DSG Control Plane
# Get these from: https://app.supabase.com → Project Settings → API

# Your Supabase project URL
# Format: https://[project-id].supabase.co
# Example: https://myproject-abc123.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://myproject.supabase.co

# Supabase Anon Key (public - safe for client-side)
# Used by the browser/frontend
# Get from: Supabase Project Settings → API → Anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImV4YW1wbGUiLCJyb2xlIjoiYW5vbiIsImlhdCI6MTYyMzg4MDAwMCwiZXhwIjoxOTIzODc2MDAwfQ.example_anon_key_string

# Supabase Service Role Key (SECRET - server-side only)
# Used by backend API routes with full database access
# SECURITY: Keep this SECRET. Never expose to browser.
# Get from: Supabase Project Settings → API → Service role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImV4YW1wbGUiLCJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNjIzODgwMDAwLCJleHAiOjE5MjM4NzYwMDB9.example_service_role_key_string

# ============================================================================
# CACHING & PERFORMANCE (REDIS)
# ============================================================================
# Upstash Redis for distributed caching and rate limiting
# Get these from: https://console.upstash.com → Redis Database

# Upstash Redis REST API URL
# Format: https://[uuid].upstash.io
# Get from: Upstash Console → Database → REST API → URL
UPSTASH_REDIS_REST_URL=https://uuid-region.upstash.io

# Upstash Redis REST API Token
# Format: AXX...
# Get from: Upstash Console → Database → REST API → Token
# SECURITY: This is a token. Protect it like a password.
UPSTASH_REDIS_REST_TOKEN=AXX1234567890abcdefghijklmnop

# ============================================================================
# CORS & SECURITY
# ============================================================================

# Comma-separated list of allowed origin URLs for API access
# These control cross-origin requests from external domains
# Format: https://domain1.com,https://domain2.com
# Leave empty to disable CORS allowlisting (not recommended for production)
# Examples:
#   - Single domain: https://app.example.com
#   - Multiple domains: https://app.example.com,https://app-staging.example.com
#   - Wildcard (NOT recommended): *
DSG_ALLOWED_ORIGINS=

# ============================================================================
# NOTES FOR SETUP WIZARD
# ============================================================================
#
# Run: ./scripts/env-setup-wizard.sh
#
# This interactive script will:
#   ✓ Guide you through entering each variable
#   ✓ Validate formats (Stripe keys, Supabase URLs, etc.)
#   ✓ Show which variables are set vs. missing
#   ✓ Allow you to edit individual variables
#   ✓ Save to .env.local (encrypted with mode 600)
#
# After setup, deploy to Vercel:
# Run: ./scripts/env-to-vercel.sh
#
# This helper will:
#   ✓ Display formatted variables ready for Vercel Dashboard
#   ✓ Show Vercel CLI commands (if installed)
#   ✓ Guide manual setup via Vercel Dashboard
#   ✓ Explain environment variable visibility (public vs. secret)
#   ✓ Show verification and rotation procedures
#
# ============================================================================
