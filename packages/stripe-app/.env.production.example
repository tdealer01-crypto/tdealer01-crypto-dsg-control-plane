# ============================================================================
# DSG Stripe App - Production Environment Variables
# ============================================================================
#
# Instructions:
# 1. Copy this file to .env.production (NEVER commit .env.production)
# 2. Replace TODO values with actual credentials from your services
# 3. For Vercel deployment, add these via dashboard Secrets:
#    Settings → Environment Variables → Add new value
# 4. Never print or expose these values in logs, PRs, or documentation
#
# ============================================================================

# ============ Stripe Configuration ============
# Get from: https://dashboard.stripe.com/apikeys

# Stripe Secret Key (sk_live_xxx or sk_test_xxx)
# Production: Use live keys (sk_live_)
# Testing: Use test keys (sk_test_)
STRIPE_SECRET_KEY=TODO_REPLACE_WITH_STRIPE_SECRET_KEY

# Webhook Secret for validating Stripe webhook signatures
# Get from: https://dashboard.stripe.com/webhooks
# Format: whsec_xxx
STRIPE_WEBHOOK_SECRET=TODO_REPLACE_WITH_WEBHOOK_SECRET

# OAuth Client ID for Stripe Apps integration
# Get from: https://dashboard.stripe.com/apps/settings
# Format: ca_xxxxx
STRIPE_APP_CLIENT_ID=TODO_REPLACE_WITH_OAUTH_CLIENT_ID

# OAuth Client Secret for Stripe Apps
# Get from: https://dashboard.stripe.com/apps/settings
# WARNING: Keep this secret and never expose in logs or versioning
STRIPE_APP_CLIENT_SECRET=TODO_REPLACE_WITH_OAUTH_CLIENT_SECRET

# ============ DSG Control Plane API Configuration ============
# DSG Control Plane API base URL (point to Vercel deployment)
DSG_API_URL=https://tdealer01-crypto-dsg-control-plane.vercel.app

# API key for authenticating requests to DSG Control Plane
# Coordinate with DSG team for production key
DSG_API_KEY=TODO_REPLACE_WITH_DSG_API_KEY

# ============ Supabase Configuration ============
# Get from: https://app.supabase.com/project/[project-id]/settings/api

# Supabase project URL
# Format: https://[project-id].supabase.co
SUPABASE_URL=TODO_REPLACE_WITH_SUPABASE_URL

# Supabase Service Role Key (server-side only)
# WARNING: Never expose to client-side code
# Store this ONLY in .env.production (server-side)
SUPABASE_SERVICE_ROLE_KEY=TODO_REPLACE_WITH_SERVICE_ROLE_KEY

# ============ Redis/Upstash Cache Configuration ============
# Get from: https://console.upstash.com/

# Upstash Redis REST API endpoint URL
# Format: https://[database-id].upstash.io
UPSTASH_REDIS_REST_URL=TODO_REPLACE_WITH_REDIS_REST_URL

# Upstash Redis REST API token
# Format: [token]
UPSTASH_REDIS_REST_TOKEN=TODO_REPLACE_WITH_REDIS_REST_TOKEN

# Cache TTL in seconds (how long to cache policy evaluations)
# Default: 300 seconds (5 minutes)
# Adjust based on policy freshness requirements
REDIS_CACHE_TTL=300

# ============ Application Configuration ============
# Node environment (must be "production" for Vercel)
NODE_ENV=production

# Logging level
# Options: debug, info, warn, error
# Production: info or warn
LOG_LEVEL=info

# ============ Monitoring & Error Tracking (Optional) ============
# Sentry error tracking
# Get from: https://sentry.io
# Format: https://[key]@o[org].ingest.sentry.io/[project]
SENTRY_DSN=TODO_OPTIONAL_REPLACE_WITH_SENTRY_DSN

# Vercel Analytics token (automatically provided by Vercel)
# This is optional - set via Vercel dashboard
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=TODO_OPTIONAL_ANALYTICS_ID

# ============ Deployment Metadata ============
# Git commit SHA (automatically set by Vercel CI/CD)
# VERCEL_GIT_COMMIT_SHA will be available at runtime

# Deployment environment
# VERCEL_ENV=production

# ============================================================================
# Deployment Instructions for Vercel
# ============================================================================
#
# 1. Via Vercel Dashboard:
#    - Go to: Settings → Environment Variables
#    - Add each variable above with actual values
#    - Ensure "Production" environment is selected
#
# 2. Via Vercel CLI:
#    vercel env add STRIPE_SECRET_KEY
#    # Then enter the value when prompted
#
# 3. Verification:
#    vercel env list
#    # Should show all variables (values hidden)
#
# ============================================================================
