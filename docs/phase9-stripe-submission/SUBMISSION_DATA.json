  "app_descriptions": {
    "about": "DSG Governance Gate displays ALLOW, BLOCK, or REVIEW policy decisions on the Stripe Dashboard payment detail view. Each decision shows its policy version, proof reference, and evaluation time inside the app panel. If the governance service is unreachable, the panel shows REVIEW — never ALLOW.",
    "about_char_count": 293,
    "about_max": 1000,
    "subtitle": "Displays ALLOW, BLOCK, or REVIEW policy decisions on payment detail views.",
    "subtitle_char_count": 74,
    "subtitle_max": 80,
    "key_features": [
      {
        "title": "Policy decision display",
        "title_char_count": 23,
        "title_max": 80,
        "description": "Each charge opened in the payment detail view shows an ALLOW, BLOCK, or REVIEW decision badge with the reason, rendered inside the Stripe Dashboard app panel.",
        "description_char_count": 158,
        "description_max": 300
      },
      {
        "title": "Decision details",
        "title_char_count": 16,
        "title_max": 80,
        "description": "Every decision shows its policy version, proof reference, and evaluation timestamp in the app panel, giving operators a verifiable record for each evaluated charge.",
        "description_char_count": 164,
        "description_max": 300
      },
      {
        "title": "Fail-safe behavior",
        "title_char_count": 18,
        "title_max": 80,
        "description": "If the governance API is unreachable or returns an unknown verdict, the panel shows REVIEW instead of ALLOW, so an outage never reads as approval.",
        "description_char_count": 146,
        "description_max": 300
      }
    ],
    "short_description": "Displays ALLOW, BLOCK, or REVIEW policy decisions on payment detail views.",
    "short_description_char_count": 74,
    "short_description_max": 140,
    "long_description": "DSG Governance Gate displays ALLOW, BLOCK, or REVIEW policy decisions on the Stripe Dashboard payment detail view.\n\nHow it works:\n- When you open a payment, the app panel sends the charge ID to the DSG governance API and displays the returned decision.\n- Each decision shows its policy version, proof reference, and evaluation timestamp.\n- If the governance service is unreachable or returns an unknown verdict, the panel shows REVIEW — never ALLOW.\n\nScope:\n- The app renders only inside the Stripe Dashboard app drawer on the payment detail view.\n- The app does not modify charges, payments, or any other Stripe object.\n\nPermissions requested:\n- Read charges, to display the governance decision for the charge you are viewing.",
    "long_description_char_count": 727,
    "long_description_max": 4000,
    "category": "Risk Management"
  },
