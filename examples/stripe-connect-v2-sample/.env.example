# Stripe API key from Dashboard > Developers > API keys.
# Use test mode first. Never commit a real key.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Local root URL. On Vercel, replace this with the deployed https URL.
ROOT_URL=http://localhost:4242

# Platform application fee in cents for direct-charge Checkout sessions.
APPLICATION_FEE_AMOUNT_CENTS=123

# Platform-level recurring price for connected-account subscriptions.
CONNECTED_ACCOUNT_SUBSCRIPTION_PRICE_ID=price_REPLACE_ME

# Signing secret from Stripe CLI thin-events listener or Dashboard event destination.
STRIPE_CONNECT_V2_THIN_WEBHOOK_SECRET=whsec_REPLACE_ME

# Signing secret from Stripe CLI billing webhook listener or Dashboard webhook endpoint.
STRIPE_BILLING_WEBHOOK_SECRET=whsec_REPLACE_ME

PORT=4242
