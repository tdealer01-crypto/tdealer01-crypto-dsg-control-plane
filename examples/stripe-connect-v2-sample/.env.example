# Stripe platform secret key.
# Fill this in with a test-mode key first. Never commit a real secret key.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Public base URL for this sample app.
# For local development with Stripe webhooks, use an HTTPS tunnel such as Stripe CLI forwarding or your preview URL.
ROOT_URL=http://localhost:4242

# Optional sample application fee for direct charges, in cents.
APPLICATION_FEE_AMOUNT_CENTS=123

# Platform-level recurring price ID used to charge the connected account for your SaaS subscription.
# Create this in your platform Stripe account before testing the subscription flow.
CONNECTED_ACCOUNT_SUBSCRIPTION_PRICE_ID=price_REPLACE_ME

# Thin-event webhook secret for Connect V2 account requirement/capability update events.
# Configure this in Stripe Dashboard or via the Stripe CLI thin-events listener.
STRIPE_CONNECT_V2_THIN_WEBHOOK_SECRET=whsec_REPLACE_ME

# Regular snapshot webhook secret for platform Billing subscription events.
STRIPE_BILLING_WEBHOOK_SECRET=whsec_REPLACE_ME

PORT=4242
