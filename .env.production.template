# Phase 8 Environment Variables Template
# Copy this, fill in your values, then paste into Vercel Dashboard

# ==================== STRIPE (5 vars) ====================
# Get from: https://dashboard.stripe.com/apikeys (Live keys)
STRIPE_API_KEY=sk_live_PASTE_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_live_PASTE_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# Get from: https://dashboard.stripe.com/webhooks (after creating endpoint)
STRIPE_WEBHOOK_SECRET=whsec_live_PASTE_YOUR_WEBHOOK_SECRET_HERE

# Get from: https://dashboard.stripe.com/settings/oauth
STRIPE_OAUTH_CLIENT_ID=ca_PASTE_YOUR_OAUTH_CLIENT_ID_HERE
STRIPE_OAUTH_CLIENT_SECRET=PASTE_YOUR_OAUTH_CLIENT_SECRET_HERE

# ==================== SUPABASE (3 vars) ====================
# Get from: https://app.supabase.com → Settings → API
SUPABASE_URL=https://PASTE_YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=PASTE_YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_SERVICE_ROLE_KEY_HERE

# ==================== UPSTASH REDIS (1 var) ====================
# Get from: https://console.upstash.com (optional)
UPSTASH_REDIS_URL=redis://default:PASTE_YOUR_REDIS_URL_HERE

# ==================== DSG (1 var) ====================
# Get from: Your DSG Control Plane
DSG_API_KEY=dsg_PASTE_YOUR_DSG_API_KEY_HERE

# ==================== DEPLOYMENT (1 var) ====================
# Keep this as-is for production
NODE_ENV=production
