# DSG Control Plane environment template
# Copy to .env.local for local development.

# -----------------------------------------------------------------------------
# Core app / runtime (required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Billing / Stripe (required in production when billing routes are enabled)
# Used by: /api/billing/checkout and /api/billing/webhook
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe price mapping (required for pricing flow)
# Preferred (plan + interval aware)
# Used by checkout + webhook price-to-plan mapping
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=

# Legacy fallback mapping (optional)
# Used only as monthly fallback in checkout/webhook for backward compatibility
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# -----------------------------------------------------------------------------
# Integrations (optional)
# -----------------------------------------------------------------------------
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
RESEND_API_KEY=

# DSG defaults (optional)
DSG_DEFAULT_POLICY_ID=policy_default
