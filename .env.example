# ============ App URLs ============
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Comma-separated cross-origin allowlist for API access
DSG_ALLOWED_ORIGINS=

# ============ Supabase ============
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============ DSG Core ============
# Optional: route all /api/* calls from UI to a real remote Control Plane API origin
# Example: https://dsg-control-plane-production.vercel.app
DSG_REMOTE_API_URL=
NEXT_PUBLIC_DSG_REMOTE_API_URL=

DSG_CORE_MODE=internal
DSG_CORE_URL=
DSG_CORE_API_KEY=
DSG_API_KEY=
DSG_DEFAULT_POLICY_ID=policy_default

# ============ Stripe App OAuth ============
# Live mode client_id for the DSG Governance Gate Stripe App (format: ca_...)
# Found in: Stripe Dashboard → Settings → Apps → DSG Governance Gate → Client ID
NEXT_PUBLIC_STRIPE_CLIENT_ID=
# Server-side secret for token exchange (code → access_token) — never expose to client
STRIPE_CLIENT_SECRET=

# ============ Stripe Billing (REQUIRED FOR PRODUCTION) ============
# Live secret key; required for live OAuth token exchange and manual deauthorization.
STRIPE_SECRET_KEY=
# Sandbox secret key; required for sandbox OAuth token exchange and manual deauthorization.
STRIPE_SANDBOX_SECRET_KEY=
# Signing secret for POST /api/billing/webhook (canonical billing webhook endpoint)
STRIPE_WEBHOOK_SECRET=
# Pro plan pricing (monthly and yearly)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
# Business plan pricing (monthly and yearly) — use for agency/team plans
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=
# Enterprise plan pricing (monthly and yearly) — use for enterprise customers
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=
# Legacy fallback pricing (deprecated — prefer monthly/yearly split above)
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
# Metered billing for execution overage
STRIPE_METER_EVENT_NAME=dsg_execution_overage
STRIPE_METER_ID=
# Overage pricing rate in USD per execution
OVERAGE_RATE_USD=0.001

# ============ Access Policy ============
ACCESS_MODE=strict
ACCESS_POLICY=strict
APPROVAL_REQUIRED_DOMAINS=
APPROVED_APPROVAL_DOMAINS=
APPROVED_AUTO_JOIN_DOMAINS=

# ============ Internal Services ============
# Used by POST /api/revenue/events and GET /api/quotas/usage for server-to-server callers.
INTERNAL_SERVICE_TOKEN=
INTERNAL_SERVICE_TOKENS=

# ============ Rate Limiting (recommended for serverless) ============
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============ SSO / Identity ============
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# ============ Demo Bootstrap (non-production) ============
ENABLE_DEMO_BOOTSTRAP=false
DEMO_BOOTSTRAP_TOKEN=

# ============ Cron & Scheduler (REQUIRED FOR PRODUCTION) ============
# Secret for cron endpoints — endpoints return 503 Service Unavailable if not set
# All /api/cron/* endpoints fail closed when CRON_SECRET is missing
CRON_SECRET=

# ============ AI & Language Models (REQUIRED FOR PRODUCTION) ============
# Anthropic Claude API key — required for marketing agent and content generation
ANTHROPIC_API_KEY=
# NVIDIA API key for GLM and other NVIDIA models
# Get from: https://build.nvidia.com/mistralai/mistral-large
NVIDIA_API_KEY=
# OpenRouter multi-model API key (optional alternative to ANTHROPIC_API_KEY)
OPENROUTER_API_KEY=
# Primary chat model for dashboard backends (hermes, agi, trinity)
# Falls back to free model if unset — name only, never commit the value
OPENROUTER_MODEL_CHAT=

# ============ Notifications ============
# Resend email service API key (optional — no-op if not set)
RESEND_API_KEY=

# ============ Marketing & Integrations (REQUIRED FOR REVENUE ACTIVATION) ============
# GitHub personal access token for leads scraper and integrations
# Scope: repo, user, workflow (minimum)
GITHUB_TOKEN=
# Marketing outreach mode: queue (human approval), auto (automatic), off (disabled)
# Default if unset: queue (safe default)
MARKETING_OUTREACH_MODE=queue
# Telegram bot token for founder notifications (optional)
TELEGRAM_BOT_TOKEN=
# Telegram chat ID for alerts (optional — use @userinfobot to find your chat ID)
TELEGRAM_CHAT_ID=
# Optional: primary chat model id for the Hermes/AGI dashboard chat backends
# (app/api/dashboard/hermes/chat, app/api/dashboard/agi/chat, app/api/trinity/*).
# Falls back to a free model when unset. Name only — never commit a value.
OPENROUTER_MODEL_CHAT=

# ============ Z.AI MCP Servers (Vision + Web Reader) ============
# GLM Coding Plan key from https://z.ai/manage-apikey/apikey-list
# Shared by the local Vision MCP server (@z_ai/mcp-server) and the remote
# Web Reader MCP server (https://api.z.ai/api/mcp/web_reader/mcp).
# Referenced as ${Z_AI_API_KEY} in .claude/settings.json — never commit the value.
Z_AI_API_KEY=
# Service platform selector for the Vision MCP server. Only ZAI is supported.
Z_AI_MODE=ZAI

# ============ Auth ============
NEXTAUTH_SECRET=
DSG_FINANCE_GOVERNANCE_ENABLED=true

# ============ GitHub App Integration ============
# Required for DSG Gate webhook and PR check-run posting
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
# Optional: override the agent_id used for DSG gate evaluation on PRs
GITHUB_APP_AGENT_ID=github-app-gate

# ============ GitHub Marketplace Integration ============
# Signing secret for /api/webhooks/marketplace (marketplace purchase events)
GITHUB_MARKETPLACE_WEBHOOK_SECRET=
# Client ID/secret for the GitHub App backing the Marketplace listing (Trinity/
# Finance Governance/Stripe billing SaaS platform) — used by
# /api/github-app/marketplace/callback to exchange the OAuth code for a token.
# This is a DIFFERENT GitHub App from GITHUB_APP_ID above (the governance-gate
# App); do not reuse or overwrite either app's credentials with the other's.
GITHUB_MARKETPLACE_OAUTH_CLIENT_ID=
GITHUB_MARKETPLACE_OAUTH_CLIENT_SECRET=

# ============ Breach Signal / HIBP ============
# No API key required — uses the free public HIBP breach list with 24-hour in-memory cache.

# ============ AI Agent Language Preference ============
# Supported languages: en, th, zh, ja, es, fr, de, ko
# Default: en (English)
# Examples: th (ไทย), en (English), zh (中文), ja (日本語)
PREFERRED_LANGUAGE=en

# Stripe App Marketplace install lifecycle (server-side)
# Copy the clean Live/Sandbox OAuth URLs from Stripe Developer Dashboard Settings.
STRIPE_LIVE_INSTALL_URL=
STRIPE_SANDBOX_INSTALL_URL=
# Mode-specific server-side client IDs used to validate install URLs and revoke access.
STRIPE_CONNECT_CLIENT_ID=
STRIPE_SANDBOX_CONNECT_CLIENT_ID=
# Unique secret used to sign and verify one-time OAuth state values.
STRIPE_CONNECT_STATE_SECRET=
# Signing secret for /api/stripe-app/webhook (account.application.deauthorized).
STRIPE_APP_WEBHOOK_SECRET=

# ============ Z3 Deterministic Solver ============
# Enable external Z3 solver for deterministic constraint verification
DSG_DETERMINISTIC_EXTERNAL_SOLVER_ENABLED=false
# URL of deployed Z3 solver service (e.g., https://z3-solver.vercel.app/api/solve)
DSG_EXTERNAL_SOLVER_URL=
# Timeout for Z3 solver requests in milliseconds (default: 5000)
DSG_SOLVER_TIMEOUT_MS=5000
# Solver identity and version for audit trail
DSG_DETERMINISTIC_SOLVER_NAME=z3
DSG_DETERMINISTIC_SOLVER_VERSION=4.16.0

# ============ Monitoring System (Phase 1-3) ============
# Enable execution monitoring globally
MONITORING_ENABLED=false
# How many days to retain monitoring data (default: 30)
MONITORING_RETENTION_DAYS=30
# Batch size for monitoring writes (for performance tuning)
MONITORING_BATCH_SIZE=100
# Flush interval for batched monitoring writes (milliseconds)
MONITORING_FLUSH_INTERVAL_MS=5000
# Enable real-time monitoring updates (Phase 3)
MONITORING_REALTIME_ENABLED=false
# Enable monitoring alerts (Phase 3)
MONITORING_ALERTS_ENABLED=false
# Slack webhook for monitoring alerts (optional)
MONITORING_SLACK_WEBHOOK=
# Discord webhook for monitoring alerts (optional)
MONITORING_DISCORD_WEBHOOK=
# PagerDuty integration key (optional)
MONITORING_PAGERDUTY_KEY=

# ============ Production WebSocket (Phase 3) ============
# URL of the production WebSocket server
# Local dev: ws://localhost:3001
# Production: wss://websocket.trinity.your-domain.com
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3001
# Redis connection string for publishing real-time updates
# Format: redis://[user]:[password]@host:port/db
REDIS_URL=redis://localhost:6379
# Enable WebSocket fallback to Server-Sent Events
WEBSOCKET_FALLBACK_ENABLED=true
# WebSocket server port (when running separately)
WS_PORT=3001

# ============ Solana Integration (Phase 3 Feature 3) ============
# Real blockchain transaction execution for SOL transfers
# Status: Production-ready for devnet/testnet testing

# Solana RPC Endpoint (required for production mode)
# Devnet: https://api.devnet.solana.com (free airdrop available)
# Testnet: https://api.testnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com (REAL SOL TRANSFERS)
SOLANA_RPC_ENDPOINT=https://api.devnet.solana.com

# Treasury Keypair - Private Key (Option A: recommended for Secret Manager)
# Format: Base64-encoded 64-byte Solana private key
# Generate: solana-keygen new --outfile treasury.json && cat treasury.json | jq -r '.[] | @base64'
# NEVER commit this value - store in GitHub Secrets or Vercel environment
SOLANA_TREASURY_PRIVATE_KEY=

# Treasury Keypair - Secret Array (Option B: alternative format)
# Format: JSON array of 64 bytes [0, 1, 2, ..., 63]
# Generate: cat treasury.json | jq '.[]'
# Use either SOLANA_TREASURY_PRIVATE_KEY or SOLANA_TREASURY_SECRET (not both)
# NEVER commit this value - store in GitHub Secrets or Vercel environment
SOLANA_TREASURY_SECRET=

# Optional: Fallback RPC endpoint for redundancy
SOLANA_RPC_ENDPOINT_FALLBACK=

# Optional: Transaction confirmation timeout in milliseconds (default: 60000)
SOLANA_CONFIRMATION_TIMEOUT_MS=60000

# Optional: Maximum retry attempts for RPC submission (default: 3, max: 10)
SOLANA_MAX_RETRIES=3

# Optional: Enable Solana integration debugging
SOLANA_DEBUG=false

# --- DSG ONE Ising live solver (optional) ---
# Endpoint for a QUBO/Ising solver you run or subscribe to (no public NVIDIA
# QUBO endpoint exists; cuOpt covers LP/MILP/QP/VRP). Leave unset to use the
# deterministic mock solver.
NVIDIA_ISING_API_URL=
# Optional bearer token for the solver endpoint
NVIDIA_ISING_API_KEY=
# Set to "live" to let optimizeWithIsing use the endpoint when useMock is unset
NVIDIA_ISING_MODE=
# Bearer key required by the self-hosted solver route /api/dsg-one/ising/solve
# (route fails closed with 503 when unset). To make a deployment solve for
# itself, set NVIDIA_ISING_API_URL to <deployment>/api/dsg-one/ising/solve
# and NVIDIA_ISING_API_KEY to the same value as this key.
DSG_ISING_SOLVER_KEY=

# --- DSG ONE LLM advisory verifier (optional) ---
# NVIDIA ising-calibration LLM as a SECONDARY analysis layer. The LLM only
# analyzes/explains deterministic solver results — it never decides validity.
# Set to "advisory" to enable; leave unset to disable (deterministic-only).
NVIDIA_LLM_VERIFIER_MODE=
# API key from build.nvidia.com (falls back to NVIDIA_ISING_API_KEY if unset)
NVIDIA_API_KEY=
# Override chat completions endpoint (default: https://integrate.api.nvidia.com/v1/chat/completions)
NVIDIA_LLM_VERIFIER_URL=
# Override model id (default: nvidia/ising-calibration-1-35b-a3b)
NVIDIA_LLM_VERIFIER_MODEL=
