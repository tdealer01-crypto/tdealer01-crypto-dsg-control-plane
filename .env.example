# ============ App URLs ============
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Comma-separated cross-origin allowlist for API access
DSG_ALLOWED_ORIGINS=

# ============ Supabase ============
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============ DSG Core ============
# Optional: route all /api/* calls from UI to a real remote Control Plane API origin
# Example: https://dsg-control-plane-production.vercel.app
DSG_REMOTE_API_URL=
NEXT_PUBLIC_DSG_REMOTE_API_URL=

DSG_CORE_MODE=internal
DSG_CORE_URL=
DSG_CORE_API_KEY=
DSG_API_KEY=
DSG_DEFAULT_POLICY_ID=policy_default

# ============ Stripe App OAuth ============
# Live mode client_id for the DSG Governance Gate Stripe App (format: ca_...)
# Found in: Stripe Dashboard → Settings → Apps → DSG Governance Gate → Client ID
NEXT_PUBLIC_STRIPE_CLIENT_ID=
# Server-side secret for token exchange (code → access_token) — never expose to client
STRIPE_CLIENT_SECRET=

# ============ Stripe Billing ============
# Live secret key; required for live OAuth token exchange and manual deauthorization.
STRIPE_SECRET_KEY=
# Sandbox secret key; required for sandbox OAuth token exchange and manual deauthorization.
STRIPE_SANDBOX_SECRET_KEY=
# Signing secret for POST /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
# Stripe Meter ID for metered/overage billing (optional — skip to disable overage pricing)
STRIPE_METER_ID=

# ============ Overage Pricing ============
OVERAGE_RATE_USD=0.001

# ============ Access Policy ============
ACCESS_MODE=strict
ACCESS_POLICY=strict
APPROVAL_REQUIRED_DOMAINS=
APPROVED_APPROVAL_DOMAINS=
APPROVED_AUTO_JOIN_DOMAINS=

# ============ Internal Services ============
# Used by POST /api/revenue/events and GET /api/quotas/usage for server-to-server callers.
INTERNAL_SERVICE_TOKEN=
INTERNAL_SERVICE_TOKENS=

# ============ Rate Limiting (recommended for serverless) ============
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============ SSO / Identity ============
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# ============ Demo Bootstrap (non-production) ============
ENABLE_DEMO_BOOTSTRAP=false
DEMO_BOOTSTRAP_TOKEN=

# ============ Notifications ============
RESEND_API_KEY=

# ============ OpenRouter (Multi-Model) ============
OPENROUTER_API_KEY=

# ============ Z.AI MCP Servers (Vision + Web Reader) ============
# GLM Coding Plan key from https://z.ai/manage-apikey/apikey-list
# Shared by the local Vision MCP server (@z_ai/mcp-server) and the remote
# Web Reader MCP server (https://api.z.ai/api/mcp/web_reader/mcp).
# Referenced as ${Z_AI_API_KEY} in .claude/settings.json — never commit the value.
Z_AI_API_KEY=
# Service platform selector for the Vision MCP server. Only ZAI is supported.
Z_AI_MODE=ZAI

# ============ Auth ============
NEXTAUTH_SECRET=
DSG_FINANCE_GOVERNANCE_ENABLED=true

# ============ GitHub App Integration ============
# Required for DSG Gate webhook and PR check-run posting
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
# Optional: override the agent_id used for DSG gate evaluation on PRs
GITHUB_APP_AGENT_ID=github-app-gate

# ============ Breach Signal / HIBP ============
# No API key required — uses the free public HIBP breach list with 24-hour in-memory cache.

# ============ AI Agent Language Preference ============
# Supported languages: en, th, zh, ja, es, fr, de, ko
# Default: en (English)
# Examples: th (ไทย), en (English), zh (中文), ja (日本語)
PREFERRED_LANGUAGE=en

# Stripe App Marketplace install lifecycle (server-side)
# Copy the clean Live/Sandbox OAuth URLs from Stripe Developer Dashboard Settings.
STRIPE_LIVE_INSTALL_URL=
STRIPE_SANDBOX_INSTALL_URL=
# Mode-specific server-side client IDs used to validate install URLs and revoke access.
STRIPE_CONNECT_CLIENT_ID=
STRIPE_SANDBOX_CONNECT_CLIENT_ID=
# Unique secret used to sign and verify one-time OAuth state values.
STRIPE_CONNECT_STATE_SECRET=
# Signing secret for /api/stripe-app/webhook (account.application.deauthorized).
STRIPE_APP_WEBHOOK_SECRET=

# ============ Z3 Deterministic Solver ============
# Enable external Z3 solver for deterministic constraint verification
DSG_DETERMINISTIC_EXTERNAL_SOLVER_ENABLED=false
# URL of deployed Z3 solver service (e.g., https://z3-solver.vercel.app/api/solve)
DSG_EXTERNAL_SOLVER_URL=
# Timeout for Z3 solver requests in milliseconds (default: 5000)
DSG_SOLVER_TIMEOUT_MS=5000
# Solver identity and version for audit trail
DSG_DETERMINISTIC_SOLVER_NAME=z3
DSG_DETERMINISTIC_SOLVER_VERSION=4.16.0

# ============ Production WebSocket (Phase 3) ============
# URL of the production WebSocket server
# Local dev: ws://localhost:3001
# Production: wss://websocket.trinity.your-domain.com
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3001
# Redis connection string for publishing real-time updates
# Format: redis://[user]:[password]@host:port/db
REDIS_URL=redis://localhost:6379
# Enable WebSocket fallback to Server-Sent Events
WEBSOCKET_FALLBACK_ENABLED=true
# WebSocket server port (when running separately)
WS_PORT=3001
